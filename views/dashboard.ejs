<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Banvath Ranjit Naik — Enhanced Dashboard</title>

  <!-- Bootstrap 5 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- ApexCharts -->
  <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

  <!-- FullCalendar (vanilla) -->
  <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/main.min.css" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/main.min.js"></script>

  <!-- GSAP -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>

  <!-- FontAwesome -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

  <style>
    /* ---------------------------
       Enhanced theme with better contrast
       --------------------------- */
    :root{
      --sidebar-bg: #2a155e; /* deep purple */
      --accent-1: #6f4ef8;
      --accent-2: #06b6d4;
      --accent-3: #f97316;
      --accent-4: #10b981;
      --card-bg: #ffffff;
      --page-bg: #f5f8ff;
      --muted: #6b7280;
      --text: #0f172a;
      --glass-border: rgba(14,18,34,0.06);
      --shadow: 0 8px 28px rgba(14,18,34,0.08);
      --shadow-lg: 0 20px 40px rgba(14,18,34,0.12);
      --settings-bg: rgba(139, 92, 246, 0.01);
    }

    *{box-sizing:border-box}
    html,body{height:100%}
    body{
      margin:0;
      font-family: Inter, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
      background: var(--page-bg);
      color:var(--text);
      -webkit-font-smoothing:antialiased;
      -moz-osx-font-smoothing:grayscale;
      padding: 18px;
    }
    a{ text-decoration:none }

    /* layout */
    .app {
      max-width:1400px;
      margin:0 auto;
      display:grid;
      grid-template-columns: 260px 1fr;
      gap:20px;
      align-items:start;
    }

    /* sidebar */
    .sidebar {
      background: linear-gradient(180deg, var(--sidebar-bg), #231045 80%);
      color: white;
      border-radius: 14px;
      padding: 18px;
      height: calc(100vh - 36px);
      position: sticky;
      top: 18px;
      box-shadow: var(--shadow);
      overflow:auto;
      border:1px solid rgba(255,255,255,0.03);
    }
    .brand { display:flex; gap:12px; align-items:center; margin-bottom:14px }
    .logo {
      width:56px;height:56px;border-radius:12px;background:linear-gradient(135deg,var(--accent-1),var(--accent-2));
      display:flex;align-items:center;justify-content:center;font-weight:800;color:white;font-size:16px;box-shadow:0 8px 28px rgba(111,78,248,0.18);
    }
    .brand h2{margin:0;font-size:16px}
    .brand p{margin:0;font-size:12px;opacity:0.85}

    .nav-link {
      display:flex; align-items:center; gap:10px; padding:12px; border-radius:10px; color:rgba(255,255,255,0.9);
      margin-bottom:8px; font-weight:600; cursor:pointer; transition: all .18s;
    }
    .nav-link:hover { transform: translateY(-3px); background: rgba(255,255,255,0.03); box-shadow: 0 5px 15px rgba(0,0,0,0.1) }
    .nav-link.active { background: linear-gradient(90deg, rgba(255,255,255,0.05), rgba(255,255,255,0.02)); box-shadow: 0 10px 30px rgba(10,10,40,0.15) }
    .nav-link i { font-size: 18px; width: 24px; text-align: center; }

    .sidebar .muted { color: rgba(255,255,255,0.7); font-size:12px }

    /* main content */
    .main {
      min-height: calc(100vh - 36px);
      overflow:auto;
    }
    .topbar {
      display:flex; justify-content:space-between; align-items:center; gap:12px;
      background: var(--card-bg); padding:12px 16px; border-radius:12px; box-shadow: var(--shadow);
      border:1px solid var(--glass-border);
      margin-bottom:14px;
    }
    .search-input { width:100%; padding:8px 12px; border-radius:10px; border:1px solid var(--glass-border); color:var(--text) }

    /* card/grid */
    .card {
      background: var(--card-bg); border-radius:12px; padding:14px; border:1px solid var(--glass-border);
      box-shadow: var(--shadow);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-lg);
    }
    .grid {
      display:grid; grid-template-columns: repeat(12,1fr); gap:14px;
    }
    .col-3 { grid-column: span 3; }
    .col-4 { grid-column: span 4; }
    .col-6 { grid-column: span 6; }
    .col-8 { grid-column: span 8; }
    .col-12 { grid-column: span 12; }

    .stat { position: relative; overflow: hidden; }
    .stat .icon { 
      width:60px;height:60px;display:flex;align-items:center;justify-content:center;border-radius:12px;
      background:linear-gradient(135deg,var(--accent-1),var(--accent-2));color:white;font-size:24px;
      box-shadow: 0 8px 20px rgba(111,78,248,0.25);
    }
    .stat:nth-child(2) .icon { background: linear-gradient(135deg, var(--accent-3), #f59e0b); }
    .stat:nth-child(3) .icon { background: linear-gradient(135deg, var(--accent-4), #34d399); }
    .stat:nth-child(4) .icon { background: linear-gradient(135deg, #8b5cf6, #a855f7); }

    /* content sections (SPA pages) - Different styles for each section */
    .section {
      display:none; /* hidden by default - JS toggles .active */
      animation: fadeIn .32s ease both;
    }
    .section.active { display:block }

    /* Different styles for each section */
    #overview { background: transparent; }
    #projectsPage { background: rgba(111, 78, 248, 0.01); }
    #clientsPage { background: rgba(6, 182, 212, 0.01); }
    #commitsPage { background: rgba(16, 185, 129, 0.01); }
    #calendarPage { background: rgba(249, 115, 22, 0.01); }
    #analyticsPage { background: rgba(139, 92, 246, 0.01); }
    #portfolioPage { background: rgba(239, 68, 68, 0.01); }
    #contactPage { background: rgba(59, 130, 246, 0.01); }
    #settingsPage { background: var(--settings-bg); }

    @keyframes fadeIn {
      from { opacity:0; transform: translateY(6px) }
      to { opacity:1; transform: translateY(0) }
    }

    /* Enhanced portfolio gallery */
    .portfolio-grid { 
      display:grid; 
      grid-template-columns: repeat(auto-fill,minmax(250px,1fr)); 
      gap:16px;
    }
    .portfolio-card { 
      border-radius:12px; 
      overflow:hidden; 
      cursor:pointer; 
      position:relative; 
      transition: transform .18s, box-shadow .18s; 
      height: 220px;
    }
    .portfolio-card img { width:100%; height:100%; object-fit:cover; display:block; transition: transform 0.3s; }
    .portfolio-card:hover { transform: translateY(-6px); box-shadow: 0 20px 40px rgba(14,18,34,0.12) }
    .portfolio-card:hover img { transform: scale(1.05); }
    .portfolio-overlay { 
      position:absolute; 
      inset:0; 
      display:flex; 
      align-items:flex-end; 
      padding:16px; 
      color:white; 
      background: linear-gradient(180deg, rgba(0,0,0,0) 30%, rgba(0,0,0,0.7));
      opacity: 0;
      transition: opacity 0.3s;
    }
    .portfolio-card:hover .portfolio-overlay { opacity: 1; }

    /* Enhanced projects grid */
    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 20px;
      margin-top: 20px;
    }
    .project-card {
      border-radius: 12px;
      overflow: hidden;
      box-shadow: var(--shadow);
      transition: all 0.3s;
      background: var(--card-bg);
      cursor: pointer;
      position: relative;
      border-left: 4px solid var(--accent-1);
    }
    .project-card:hover {
      transform: translateY(-5px);
      box-shadow: var(--shadow-lg);
      border-left: 4px solid var(--accent-2);
    }
    .project-image {
      height: 160px;
      width: 100%;
      object-fit: cover;
    }
    .project-content {
      padding: 16px;
    }
    .project-tech {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 10px;
    }
    .tech-tag {
      background: rgba(111,78,248,0.1);
      color: var(--accent-1);
      padding: 4px 8px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 500;
    }

    /* Clients Grid */
    .clients-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 20px;
      margin-top: 20px;
    }
    .client-card {
      background: var(--card-bg);
      border-radius: 12px;
      padding: 20px;
      display: flex;
      align-items: center;
      gap: 15px;
      cursor: pointer;
      transition: all 0.3s;
      position: relative;
      border-left: 4px solid var(--accent-2);
    }
    .client-card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-lg);
      border-left: 4px solid var(--accent-1);
    }
    .client-avatar {
      width: 60px;
      height: 60px;
      border-radius: 12px;
      object-fit: cover;
      border: 3px solid var(--accent-2);
    }

    /* calendar */
    #calendar { border-radius:8px; padding:8px; background:transparent }
    .fc .fc-button { background: var(--accent-1) !important; border-color: var(--accent-1) !important; }
    .fc .fc-button:hover { background: var(--accent-2) !important; border-color: var(--accent-2) !important; }
    .fc .fc-button-primary:not(:disabled).fc-button-active { background: var(--accent-3) !important; }

    /* Enhanced Modal Styles */
    .overlay-modal {
      position:fixed; inset:0; display:none; align-items:center; justify-content:center; z-index:4000;
      background: rgba(3,7,18,0.8);
      backdrop-filter: blur(4px);
      padding: 20px;
    }
    .overlay-modal.show { display:flex }

    .modal-box {
      background: var(--card-bg);
      border-radius: 16px;
      max-width: 900px;
      width: 100%;
      max-height: 90vh;
      overflow-y: auto;
      animation: modalAppear 0.3s ease;
    }

    @keyframes modalAppear {
      from { opacity: 0; transform: scale(0.9); }
      to { opacity: 1; transform: scale(1); }
    }

    .modal-header {
      padding: 20px;
      border-bottom: 1px solid var(--glass-border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .modal-body {
      padding: 20px;
    }

    .modal-images {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 15px;
      margin: 20px 0;
    }

    .modal-img {
      border-radius: 10px;
      overflow: hidden;
      height: 200px;
      transition: transform 0.3s;
    }
    
    .modal-img:hover {
      transform: scale(1.02);
    }

    .modal-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* Simple modal for lightbox */
    .overlay-modal .box { 
      width:90%; max-width:820px; border-radius:16px; overflow:hidden; 
      box-shadow: 0 25px 50px rgba(0,0,0,0.25);
      animation: modalAppear 0.3s ease;
    }

    /* Enhanced contact form */
    .contact-info-card {
      background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
      color: white;
      border-radius: 12px;
      padding: 20px;
      height: 100%;
    }
    .contact-info-item {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 16px;
    }
    .contact-info-item i {
      font-size: 20px;
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(255,255,255,0.2);
      border-radius: 50%;
    }

    /* Edit Options */
    .edit-options {
      position: absolute;
      top: 10px;
      right: 10px;
      display: flex;
      gap: 5px;
      opacity: 0;
      transition: opacity 0.3s;
    }
    .project-card:hover .edit-options,
    .client-card:hover .edit-options {
      opacity: 1;
    }
    .edit-btn, .delete-btn {
      width: 30px;
      height: 30px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      border: none;
      cursor: pointer;
      font-size: 12px;
      transition: transform 0.2s;
    }
    .edit-btn {
      background: var(--accent-1);
      color: white;
    }
    .edit-btn:hover {
      background: var(--accent-2);
      transform: scale(1.1);
    }
    .delete-btn {
      background: #ef4444;
      color: white;
    }
    .delete-btn:hover {
      background: #dc2626;
      transform: scale(1.1);
    }

    /* Enhanced Contact Section */
    .contact-section {
      padding: 40px 0;
    }
    
    .contact-form-container {
      background: var(--card-bg);
      border-radius: 16px;
      padding: 40px;
      box-shadow: var(--shadow-lg);
    }
    
    .contact-form-container h3 {
      color: var(--sidebar-bg);
      margin-bottom: 10px;
      font-weight: 700;
    }
    
    .contact-form-container .form-label {
      font-weight: 600;
      color: var(--text);
      margin-bottom: 8px;
    }
    
    .contact-form-container .form-control {
      border: 1px solid var(--glass-border);
      border-radius: 10px;
      padding: 12px 16px;
      transition: all 0.3s;
      background: rgba(255, 255, 255, 0.9);
    }
    
    .contact-form-container .form-control:focus {
      border-color: var(--accent-1);
      box-shadow: 0 0 0 3px rgba(111, 78, 248, 0.1);
    }
    
    .contact-form-container .btn-submit {
      background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
      color: white;
      border: none;
      padding: 14px 32px;
      border-radius: 10px;
      font-weight: 600;
      transition: all 0.3s;
      width: 100%;
    }
    
    .contact-form-container .btn-submit:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 25px rgba(111, 78, 248, 0.3);
    }
    
    .social-links {
      display: flex;
      gap: 15px;
      margin-top: 20px;
    }
    
    .social-link {
      width: 45px;
      height: 45px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--page-bg);
      color: var(--accent-1);
      font-size: 18px;
      transition: all 0.3s;
      text-decoration: none;
    }
    
    .social-link:hover {
      background: var(--accent-1);
      color: white;
      transform: translateY(-3px);
    }
    
    .contact-feature {
      display: flex;
      align-items: center;
      gap: 15px;
      margin-bottom: 25px;
      padding: 20px;
      background: rgba(111, 78, 248, 0.05);
      border-radius: 12px;
    }
    
    .contact-feature i {
      font-size: 24px;
      color: var(--accent-1);
      width: 50px;
      height: 50px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: white;
      border-radius: 12px;
    }

    /* Settings Page Styles */
    .settings-section {
      padding: 20px 0;
    }
    
    .settings-card {
      border-left: 4px solid var(--accent-1);
    }
    
    .settings-item {
      padding: 15px;
      border-bottom: 1px solid var(--glass-border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    
    .settings-item:last-child {
      border-bottom: none;
    }
    
    .settings-item label {
      font-weight: 600;
      color: var(--text);
    }
    
    .settings-item .form-text {
      color: var(--muted);
      font-size: 13px;
      margin-top: 5px;
    }
    
    .form-switch .form-check-input:checked {
      background-color: var(--accent-1);
      border-color: var(--accent-1);
    }
    
    .color-picker {
      width: 30px;
      height: 30px;
      border-radius: 6px;
      border: 2px solid var(--glass-border);
      cursor: pointer;
      margin-right: 10px;
    }
    
    .color-picker.active {
      border-color: var(--accent-1);
      box-shadow: 0 0 0 3px rgba(111, 78, 248, 0.2);
    }
    
    .theme-preview {
      width: 100px;
      height: 60px;
      border-radius: 8px;
      border: 2px solid var(--glass-border);
      overflow: hidden;
      cursor: pointer;
      transition: all 0.3s;
    }
    
    .theme-preview:hover {
      transform: scale(1.05);
    }
    
    .theme-preview.active {
      border-color: var(--accent-1);
      box-shadow: 0 0 0 3px rgba(111, 78, 248, 0.2);
    }
    
    .theme-preview .theme-sidebar {
      width: 30px;
      height: 100%;
      background: var(--sidebar-bg);
      float: left;
    }
    
    .theme-preview .theme-main {
      width: 70px;
      height: 100%;
      background: var(--page-bg);
      float: left;
    }

    /* responsive */
    @media (max-width:1100px){
      .app { grid-template-columns: 1fr; }
      .sidebar { position:relative; height:auto; }
      .grid { grid-template-columns: repeat(6,1fr) }
      .col-3{grid-column:span 3} .col-4{grid-column:span 6} .col-6{grid-column:span 6} .col-8{grid-column:span 6}
    }
    
    /* Enhanced filter for portfolio */
    .filter-buttons {
      display: flex;
      gap: 10px;
      margin-bottom: 20px;
      flex-wrap: wrap;
    }
    .filter-btn {
      background: var(--card-bg);
      border: 1px solid var(--glass-border);
      border-radius: 20px;
      padding: 6px 16px;
      font-size: 14px;
      cursor: pointer;
      transition: all 0.2s;
    }
    .filter-btn.active, .filter-btn:hover {
      background: var(--accent-1);
      color: white;
    }
    
    /* Stats hover effects */
    .stat-card {
      cursor: pointer;
      transition: all 0.3s;
    }
    .stat-card:hover {
      transform: translateY(-5px);
    }
    
    /* Calendar event details */
    .event-details {
      padding: 15px;
      background: white;
      border-radius: 10px;
      margin-top: 10px;
    }

    /* Status badges */
    .status-badge {
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
    }
    .status-completed { background: #10b98120; color: #10b981; }
    .status-in-progress { background: #3b82f620; color: #3b82f6; }
    .status-planning { background: #f59e0b20; color: #f59e0b; }
    .status-on-hold { background: #6b728020; color: #6b7280; }
    .status-active { background: #06b6d420; color: #06b6d4; }

    /* Search and filter bar */
    .search-filter-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
      flex-wrap: wrap;
      gap: 10px;
    }
    .search-box {
      display: flex;
      align-items: center;
      gap: 10px;
      flex: 1;
      max-width: 400px;
    }
    .search-box input {
      flex: 1;
      padding: 8px 12px;
      border-radius: 8px;
      border: 1px solid var(--glass-border);
      background: var(--card-bg);
      color: var(--text);
    }

    /* Toast notifications */
    .toast {
      position: fixed;
      top: 20px;
      right: 20px;
      background: #10b981;
      color: white;
      padding: 12px 20px;
      border-radius: 8px;
      box-shadow: var(--shadow-lg);
      z-index: 9999;
      animation: slideIn 0.3s ease;
    }
    
    @keyframes slideIn {
      from { transform: translateX(100%); opacity: 0; }
      to { transform: translateX(0); opacity: 1; }
    }
    
    @keyframes slideOut {
      from { transform: translateX(0); opacity: 1; }
      to { transform: translateX(100%); opacity: 0; }
    }

    /* Section headers with unique styles */
    .section-header {
      padding: 20px;
      border-radius: 12px;
      margin-bottom: 20px;
      background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
      color: white;
    }
    
    #projectsPage .section-header { background: linear-gradient(135deg, var(--accent-1), #8b5cf6); }
    #clientsPage .section-header { background: linear-gradient(135deg, var(--accent-2), #06b6d4); }
    #commitsPage .section-header { background: linear-gradient(135deg, var(--accent-4), #34d399); }
    #calendarPage .section-header { background: linear-gradient(135deg, var(--accent-3), #f59e0b); }
    #analyticsPage .section-header { background: linear-gradient(135deg, #8b5cf6, #a855f7); }
    #portfolioPage .section-header { background: linear-gradient(135deg, #ef4444, #f97316); }
    #contactPage .section-header { background: linear-gradient(135deg, #3b82f6, #06b6d4); }
    #settingsPage .section-header { background: linear-gradient(135deg, #6366f1, #8b5cf6); }
    
    /* Danger zone for settings */
    .danger-zone {
      border: 2px solid #ef4444;
      border-radius: 12px;
      padding: 20px;
      background: rgba(239, 68, 68, 0.05);
    }
    
    .danger-zone h5 {
      color: #ef4444;
    }
    
    /* Calendar add button */
    .fc-addEvent-button {
      background: var(--accent-4) !important;
      border-color: var(--accent-4) !important;
    }
  </style>
</head>
<body>
  <div class="app" role="application" aria-label="Dashboard app">

    <!-- SIDEBAR -->
    <aside class="sidebar" aria-label="Sidebar">
      <div class="brand" role="banner">
        <div class="logo" aria-hidden="true">BRN</div>
        <div>
          <h2>Banvath Ranjit Naik</h2>
          <div class="muted">Full Stack Developer</div>
        </div>
      </div>

      <!-- nav -->
      <nav aria-label="Main navigation" role="navigation">
        <div class="nav-link active" data-target="overview"><i class="fa-solid fa-house"></i> Overview</div>
        <div class="nav-link" data-target="projectsPage"><i class="fa-regular fa-folder-open"></i> Projects</div>
        <div class="nav-link" data-target="clientsPage"><i class="fa-solid fa-users"></i> Clients</div>
