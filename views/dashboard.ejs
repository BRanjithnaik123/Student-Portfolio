    // =============== Setup Functions ===============
    function setupEventListeners() {
      // Close modals on outside click
      window.addEventListener('click', function(event) {
        if (event.target.classList.contains('overlay-modal')) {
          closeModal();
          closeRevenueDetails();
          closeAddProjectModal();
          closeAddClientModal();
          closeEditProjectModal();
          closeEditClientModal();
          closeAddEventModal();
          closeProfileModal();
        }
      });

      // Close modal with Escape key
      document.addEventListener('keydown', function(event) {
        if (event.key === 'Escape') {
          closeModal();
          closeRevenueDetails();
          closeAddProjectModal();
          closeAddClientModal();
          closeEditProjectModal();
          closeEditClientModal();
          closeAddEventModal();
          closeProfileModal();
        }
      });

      // Range selector for charts
      const rangeSelect = document.getElementById('rangeSelect');
      if (rangeSelect) {
        rangeSelect.addEventListener('change', function() {
          updateCharts(parseInt(this.value));
        });
      }
      
      // Portfolio filter buttons
      document.querySelectorAll('#portfolioPage .filter-btn').forEach(btn => {
        btn.addEventListener('click', function() {
          const filter = this.getAttribute('data-filter');
          filterPortfolioItems(filter);
        });
      });
    }

    function setupAnimations() {
      // Animate numbers
      animateNumber('projectsCount', projectsData.length);
      animateNumber('clientsCount', clientsData.length);
      animateNumber('commitsCount', 230);
      animateNumber('revenue', 12000);

      // GSAP animations for cards
      gsap.from('.card', { y: 10, opacity: 0, stagger: 0.03, duration: 0.45, ease: 'power3.out' });
    }

    function animateNumber(elId, to){
      const el = document.getElementById(elId);
      if(!el) return;
      let cur = 0; const step = Math.max(1, Math.round(to/40));
      const iv = setInterval(()=> {
        cur += step;
        if(cur >= to){ cur = to; clearInterval(iv); }
        if(elId === 'revenue') el.textContent = '$' + cur.toLocaleString();
        else el.textContent = cur;
      }, 18);
    }

    function showToast(message, type = 'info') {
      // Create toast element
      const toast = document.createElement('div');
      toast.className = 'toast';
      toast.style.background = type === 'success' ? '#10b981' : type === 'error' ? '#ef4444' : '#3b82f6';
      
      toast.innerHTML = `
        <div style="display: flex; align-items: center; gap: 10px;">
          <i class="fa-solid ${type === 'success' ? 'fa-check-circle' : type === 'error' ? 'fa-exclamation-circle' : 'fa-info-circle'}"></i>
          <span>${message}</span>
        </div>
      `;
      
      document.body.appendChild(toast);
      
      // Remove after 3 seconds
      setTimeout(() => {
        toast.style.animation = 'slideOut 0.3s ease';
        setTimeout(() => {
          document.body.removeChild(toast);
        }, 300);
      }, 3000);
    }

    // =============== Dashboard Functions ===============
    // SPA navigation: show/hide sections
    const sections = {
      overview: document.getElementById('overview'),
      projectsPage: document.getElementById('projectsPage'),
      clientsPage: document.getElementById('clientsPage'),
      commitsPage: document.getElementById('commitsPage'),
      calendarPage: document.getElementById('calendarPage'),
      analyticsPage: document.getElementById('analyticsPage'),
      portfolioPage: document.getElementById('portfolioPage'),
      contactPage: document.getElementById('contactPage'),
      settingsPage: document.getElementById('settingsPage')
    };

    function hideAllSections() {
      Object.values(sections).forEach(s => s.classList.remove('active'));
    }

    function setActiveNav(targetName) {
      document.querySelectorAll('.nav-link').forEach(n => {
        n.classList.toggle('active', n.getAttribute('data-target') === targetName);
      });
    }

    function showSection(targetName) {
      if (!sections[targetName]) return;
      hideAllSections();
      sections[targetName].classList.add('active');
      setActiveNav(targetName);
      
      // some charts/redraws when showing pages
      if (targetName === 'calendarPage') {
        setTimeout(() => { if(window.calendar) window.calendar.render(); }, 80);
      }
      if (targetName === 'analyticsPage') {
        setTimeout(() => { try { areaChartBig.render(); barChartBig.render(); donutBig.render(); projectStatusChart.render(); } catch(e){} }, 80);
      }
      if (targetName === 'commitsPage') {
        setTimeout(() => { try { commitChart.render(); } catch(e){} }, 80);
      }
      
      // small entrance animation
      gsap.from(sections[targetName], { y: 8, opacity:0, duration: 0.36, ease:'power3.out' });
      // close mobile sidebar if open
      if(window.innerWidth < 1100) document.querySelector('.sidebar').style.display = 'none';
    }

    // bind nav clicks
    document.querySelectorAll('.nav-link').forEach(link => {
      link.addEventListener('click', (e) => {
        const target = e.currentTarget.getAttribute('data-target');
        showSection(target);
      });
    });

    // quick open project from overview
    function openProjectAndShow(projectId){
      showSection('projectsPage');
