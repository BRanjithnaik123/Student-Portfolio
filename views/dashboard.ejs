    // =============== Calendar Functions ===============
    function initializeCalendar() {
      const calendarEl = document.getElementById('calendar');
      if (!calendarEl) return;
      
      const calendar = new FullCalendar.Calendar(calendarEl, {
        initialView: 'dayGridMonth',
        height: 580,
        headerToolbar: { 
          left: 'prev,next today', 
          center: 'title', 
          right: 'dayGridMonth,timeGridWeek,timeGridDay' 
        },
        editable: true,
        selectable: true,
        selectMirror: true,
        dayMaxEvents: true,
        events: calendarEvents,
        select: function(info) {
          // When a date is selected, open add event modal with that date
          showAddEventModal(info.startStr, info.endStr);
        },
        eventClick: function(info) {
          info.jsEvent.preventDefault();
          document.getElementById('eventTitle').textContent = info.event.title;
          document.getElementById('eventDescription').textContent = info.event.extendedProps.description || 'No description available.';
          document.getElementById('eventDate').textContent = info.event.start.toLocaleDateString();
          document.getElementById('eventDetails').style.display = 'block';
        },
        dateClick: function(info) {
          // Click on date to add event
          showAddEventModal(info.dateStr);
        }
      });
      
      if (sections.calendarPage.classList.contains('active')) {
        calendar.render();
      }
      window.calendar = calendar;
    }

    function showAddEventModal(startDate = '', endDate = '') {
      const modal = document.getElementById('addEventModal');
      const startInput = document.getElementById('eventStart');
      const endInput = document.getElementById('eventEnd');
      
      // Set default dates if provided
      if (startDate) {
        const startDateTime = new Date(startDate);
        const endDateTime = endDate ? new Date(endDate) : new Date(startDateTime.getTime() + 60 * 60 * 1000); // +1 hour
        
        // Format for datetime-local input
        startInput.value = startDateTime.toISOString().slice(0, 16);
        endInput.value = endDateTime.toISOString().slice(0, 16);
      } else {
        // Default to now
        const now = new Date();
        const oneHourLater = new Date(now.getTime() + 60 * 60 * 1000);
        
        startInput.value = now.toISOString().slice(0, 16);
        endInput.value = oneHourLater.toISOString().slice(0, 16);
      }
      
      modal.classList.add('show');
      modal.style.display = 'flex';
    }

    function closeAddEventModal() {
      document.getElementById('addEventModal').classList.remove('show');
      document.getElementById('addEventModal').style.display = 'none';
      document.getElementById('newEventForm').reset();
    }

    function selectEventColor(color) {
      document.getElementById('eventColor').value = color;
      document.querySelectorAll('#addEventModal .color-picker').forEach(picker => {
        picker.classList.remove('active');
        if (picker.getAttribute('data-color') === color) {
          picker.classList.add('active');
        }
      });
    }

    // Event Form Submission
    document.getElementById('newEventForm').addEventListener('submit', function(e) {
      e.preventDefault();
      
      const title = document.getElementById('eventTitle').value;
      const description = document.getElementById('eventDescription').value;
      const start = document.getElementById('eventStart').value;
      const end = document.getElementById('eventEnd').value;
      const color = document.getElementById('eventColor').value;
      const type = document.getElementById('eventType').value;
      const allDay = document.getElementById('allDayEvent').checked;
      
      const newEvent = {
        id: 'event-' + Date.now(),
        title: title,
        start: start,
        end: end,
        color: color,
        description: description,
        type: type,
        allDay: allDay
      };
      
      // Add to calendar
      if (window.calendar) {
        window.calendar.addEvent(newEvent);
      }
      
      // Add to local data
      calendarEvents.push(newEvent);
      
      closeAddEventModal();
      showToast('Event added successfully!', 'success');
      
      // Hide event details if open
      document.getElementById('eventDetails').style.display = 'none';
    });

