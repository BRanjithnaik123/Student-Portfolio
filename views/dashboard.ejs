    // Edit Client Form
    document.getElementById('editClientForm').addEventListener('submit', function(e) {
      e.preventDefault();
      
      const clientId = parseInt(document.getElementById('editClientId').value);
      const clientIndex = clientsData.findIndex(c => c.id === clientId);
      
      if (clientIndex !== -1) {
        clientsData[clientIndex] = {
          ...clientsData[clientIndex],
          name: document.getElementById('editClientName').value,
          company: document.getElementById('editClientCompany').value,
          email: document.getElementById('editClientEmail').value,
          phone: document.getElementById('editClientPhone').value,
          description: document.getElementById('editClientDescription').value,
          avatar: document.getElementById('editClientAvatar').value,
          status: document.getElementById('editClientStatus').value
        };
        
        loadClients();
        closeEditClientModal();
        showToast('Client updated successfully!', 'success');
