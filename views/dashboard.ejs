    // =============== Settings Functions ===============
    function loadSettings() {
      // Load saved settings from localStorage or use defaults
      const savedSettings = localStorage.getItem('dashboardSettings');
      if (savedSettings) {
        settingsData = JSON.parse(savedSettings);
      }
      
      // Apply settings
      applySettings();
      
      // Update settings UI
      updateSettingsUI();
    }

    function saveSettings() {
      localStorage.setItem('dashboardSettings', JSON.stringify(settingsData));
      showToast('Settings saved successfully!', 'success');
    }

    function applySettings() {
      // Apply theme
      changeTheme(settingsData.theme, false);
      
      // Apply sidebar color
      changeSidebarColor(settingsData.sidebarColor, false);
      
      // Apply refresh interval
      setupDataRefresh();
      
      // Update UI elements
      document.getElementById('emailNotifications').checked = settingsData.emailNotifications;
      document.getElementById('pushNotifications').checked = settingsData.pushNotifications;
      document.getElementById('refreshInterval').value = settingsData.refreshInterval;
      document.getElementById('defaultView').value = settingsData.defaultView;
      document.getElementById('twoFactorAuth').checked = settingsData.twoFactorAuth;
    }

    function updateSettingsUI() {
      // Update theme previews
      document.querySelectorAll('.theme-preview').forEach(preview => {
        preview.classList.remove('active');
        if (preview.getAttribute('data-theme') === settingsData.theme) {
          preview.classList.add('active');
        }
      });
      
      // Update sidebar colors
      document.querySelectorAll('#sidebarColors .color-picker').forEach(picker => {
        picker.classList.remove('active');
        if (picker.getAttribute('data-color') === settingsData.sidebarColor) {
          picker.classList.add('active');
        }
      });
    }

    function changeTheme(theme, save = true) {
      settingsData.theme = theme;
      
      // Remove existing theme classes
      document.body.classList.remove('theme-dark', 'theme-light');
      
      // Apply new theme
      if (theme === 'dark') {
        document.body.classList.add('theme-dark');
        document.documentElement.style.setProperty('--sidebar-bg', '#1a1a2e');
        document.documentElement.style.setProperty('--page-bg', '#16213e');
        document.documentElement.style.setProperty('--card-bg', '#0f172a');
        document.documentElement.style.setProperty('--text', '#f8fafc');
        document.documentElement.style.setProperty('--muted', '#94a3b8');
      } else if (theme === 'light') {
        document.body.classList.add('theme-light');
        document.documentElement.style.setProperty('--sidebar-bg', '#4361ee');
        document.documentElement.style.setProperty('--page-bg', '#f8f9fa');
        document.documentElement.style.setProperty('--card-bg', '#ffffff');
        document.documentElement.style.setProperty('--text', '#212529');
        document.documentElement.style.setProperty('--muted', '#6c757d');
      } else {
        // Default theme
        document.documentElement.style.setProperty('--sidebar-bg', '#2a155e');
        document.documentElement.style.setProperty('--page-bg', '#f5f8ff');
        document.documentElement.style.setProperty('--card-bg', '#ffffff');
        document.documentElement.style.setProperty('--text', '#0f172a');
        document.documentElement.style.setProperty('--muted', '#6b7280');
      }
      
      // Update UI
      updateSettingsUI();
      
      if (save) {
        saveSettings();
      }
    }

    function changeSidebarColor(color, save = true) {
      settingsData.sidebarColor = color;
      document.documentElement.style.setProperty('--sidebar-bg', color);
      
      // Update UI
      updateSettingsUI();
      
      if (save) {
        saveSettings();
      }
    }

    function setupDataRefresh() {
      // Clear existing interval
      if (window.dataRefreshInterval) {
        clearInterval(window.dataRefreshInterval);
      }
      
      // Set up new interval
      const interval = settingsData.refreshInterval * 60 * 1000; // Convert to milliseconds
      if (interval > 0) {
        window.dataRefreshInterval = setInterval(() => {
          // Refresh data here
          refreshDashboardData();
        }, interval);
      }
    }

    function refreshDashboardData() {
      // Refresh chart data
      updateCharts(parseInt(document.getElementById('rangeSelect').value) || 30);
      
      // Update counts with slight random variation for demo
      const projectsCount = document.getElementById('projectsCount');
      const clientsCount = document.getElementById('clientsCount');
      const commitsCount = document.getElementById('commitsCount');
      const revenue = document.getElementById('revenue');
      
      if (projectsCount) {
        const current = parseInt(projectsCount.textContent);
        projectsCount.textContent = current + (Math.random() > 0.7 ? 1 : 0);
      }
      
      if (clientsCount) {
        const current = parseInt(clientsCount.textContent);
        clientsCount.textContent = current + (Math.random() > 0.8 ? 1 : 0);
      }
      
      if (commitsCount) {
        const current = parseInt(commitsCount.textContent);
        commitsCount.textContent = current + Math.floor(Math.random() * 10);
      }
      
      if (revenue) {
        const current = parseInt(revenue.textContent.replace('$', '').replace('k', '000'));
        revenue.textContent = '$' + (current + Math.floor(Math.random() * 1000)).toLocaleString();
      }
      
      showToast('Dashboard data refreshed', 'info');
    }

