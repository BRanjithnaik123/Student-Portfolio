    function updateCharts(days) {
      const data = Array.from({length: days}, (_, i) => Math.round(300 + Math.sin(i/3)*80 + Math.random()*200));
      
      // Update overview charts
      const areaChart = ApexCharts.getChartByID("areaChart");
      if (areaChart) {
        areaChart.updateSeries([{ data }]);
        areaChart.updateOptions({
          xaxis: { categories: Array.from({length: days}, (_, i) => `Day ${i+1}`) }
        });
      }
      
      // Update analytics charts
      const areaChartBig = ApexCharts.getChartByID("areaChartBig");
      if (areaChartBig) {
        areaChartBig.updateSeries([{ data }]);
        areaChartBig.updateOptions({
          xaxis: { categories: Array.from({length: days}, (_, i) => `Day ${i+1}`) }
        });
      }
    }

